#. type: Title ###
#: ../src/guide/views/widget.md
#, no-wrap
msgid "HTML Encoding"
msgstr "HTML 编码"

#. type: Plain text
#: ../src/guide/views/widget.md
msgid "Always encode user data:"
msgstr "始终对用户数据进行编码："

#. type: Fenced code block (php)
#: ../src/guide/views/widget.md
