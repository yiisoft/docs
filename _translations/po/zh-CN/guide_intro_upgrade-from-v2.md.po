#. type: Title ##
#: ../src/guide/intro/upgrade-from-v2.md
#, no-wrap
msgid "Active Record and persistence"
msgstr ""

#. type: Plain text
#: ../src/guide/intro/upgrade-from-v2.md
msgid "There are two common Yii3 choices for code that used Yii 2.0 Active Record classes."
msgstr ""

#. type: Plain text
#: ../src/guide/intro/upgrade-from-v2.md
msgid "The first path is architectural: move business logic to services and domain objects, then use repositories for persistence. This is recommended when the Yii 2.0 model contains validation, form scenarios, authorization checks, mailing, file uploads, and database access in the same class."
msgstr ""

#. type: Plain text
#: ../src/guide/intro/upgrade-from-v2.md
msgid "The second path is incremental: represent the database model with [yiisoft/active-record](https://github.com/yiisoft/active-record). This is closer to Yii 2.0 and can be significantly faster when your Active Record classes mostly describe tables and relations."
msgstr ""

#. type: Plain text
#: ../src/guide/intro/upgrade-from-v2.md
msgid "Yii 2.0:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/intro/upgrade-from-v2.md
#, no-wrap
msgid ""
"final class Post extends \\yii\\db\\ActiveRecord\n"
"{\n"
"    public static function tableName(): string\n"
"    {\n"
"        return '{{%post}}';\n"
"    }\n"
"\n"
"    public function rules(): array\n"
"    {\n"
"        return [\n"
"            [['title', 'body'], 'required'],\n"
"            ['title', 'string', 'max' => 255],\n"
"        ];\n"
"    }\n"
"}\n"
msgstr ""

#. type: Plain text
#: ../src/guide/intro/upgrade-from-v2.md
msgid "Yii3 Active Record:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/intro/upgrade-from-v2.md
#, no-wrap
msgid ""
"use Yiisoft\\ActiveRecord\\ActiveRecord;\n"
"\n"
"final class Post extends ActiveRecord\n"
"{\n"
"    protected int $id;\n"
"    protected string $title;\n"
"    protected string $body;\n"
"\n"
"    public function tableName(): string\n"
"    {\n"
"        return '{{%post}}';\n"
"    }\n"
"\n"
"    public function getId(): ?int\n"
"    {\n"
"        return $this->id ?? null;\n"
"    }\n"
"\n"
"    public function getTitle(): ?string\n"
"    {\n"
"        return $this->title ?? null;\n"
"    }\n"
"\n"
"    public function setTitle(string $title): void\n"
"    {\n"
"        $this->title = $title;\n"
"    }\n"
"}\n"
msgstr ""

#. type: Plain text
#: ../src/guide/intro/upgrade-from-v2.md
msgid "Do not move Yii 2.0 `rules()` directly into the Active Record class. In Yii3, validation belongs to validator rules, form models, command objects, or services:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/intro/upgrade-from-v2.md
#, no-wrap
msgid ""
"use Yiisoft\\FormModel\\FormModel;\n"
"use Yiisoft\\Validator\\Rule\\Length;\n"
"use Yiisoft\\Validator\\Rule\\Required;\n"
"\n"
"final class PostInput extends FormModel\n"
"{\n"
"    #[Required]\n"
"    #[Length(max: 255)]\n"
"    public ?string $title = null;\n"
"\n"
"    #[Required]\n"
"    public ?string $body = null;\n"
"}\n"
msgstr ""

#. type: Plain text
#: ../src/guide/intro/upgrade-from-v2.md
msgid "Then copy validated data into the record or pass it to an application service:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/intro/upgrade-from-v2.md
#, no-wrap
msgid ""
"$post = new Post();\n"
"$post->setTitle($input->title);\n"
"$post->save();\n"
msgstr ""

