#. type: Bullet: '- '
#: ../src/guide/intro/upgrade-from-v1.md
msgid "persistence: repositories, `yiisoft/db`, or `yiisoft/active-record`;"
msgstr ""

#. type: Bullet: '- '
#: ../src/guide/intro/upgrade-from-v1.md
msgid "business workflows: application services."
msgstr ""

#. type: Plain text
#: ../src/guide/intro/upgrade-from-v1.md
msgid "Yii 1.1 form model:"
