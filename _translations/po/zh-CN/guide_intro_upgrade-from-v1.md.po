#. type: Fenced code block (php)
#: ../src/guide/intro/upgrade-from-v1.md
#, no-wrap
msgid ""
"class ContactForm extends CFormModel\n"
"{\n"
"    public $name;\n"
"    public $email;\n"
"\n"
"    public function rules()\n"
"    {\n"
"        return [\n"
"            ['name, email', 'required'],\n"
"            ['email', 'email'],\n"
"        ];\n"
"    }\n"
"}\n"
msgstr ""

#. type: Plain text
#: ../src/guide/intro/upgrade-from-v1.md
msgid "Yii3 form model:"
