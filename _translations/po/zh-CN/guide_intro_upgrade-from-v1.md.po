"use Yiisoft\\FormModel\\FormModel;\n"
"use Yiisoft\\Validator\\Rule\\Email;\n"
"use Yiisoft\\Validator\\Rule\\Required;\n"
"\n"
"final class ContactForm extends FormModel\n"
"{\n"
"    #[Required]\n"
"    public ?string $name = null;\n"
"\n"
"    #[Required]\n"
"    #[Email]\n"
"    public ?string $email = null;\n"
"}\n"
