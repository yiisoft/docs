#. type: Title ##
#: ../src/guide/intro/upgrade-from-v1.md
#, no-wrap
msgid "Active Record"
msgstr ""

#. type: Plain text
#: ../src/guide/intro/upgrade-from-v1.md
msgid "Yii 1.1 Active Record uses `CActiveRecord::model()` and dynamic attributes:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/intro/upgrade-from-v1.md
#, no-wrap
msgid ""
"class Post extends CActiveRecord\n"
"{\n"
"    public static function model($className = __CLASS__)\n"
"    {\n"
"        return parent::model($className);\n"
"    }\n"
"\n"
"    public function tableName()\n"
"    {\n"
"        return '{{post}}';\n"
"    }\n"
"\n"
"    public function rules()\n"
"    {\n"
"        return [\n"
"            ['title, body', 'required'],\n"
"            ['title', 'length', 'max' => 255],\n"
"        ];\n"
"    }\n"
"}\n"
msgstr ""

#. type: Plain text
#: ../src/guide/intro/upgrade-from-v1.md
#, fuzzy
#| msgid "Application bootstrapping for [yiisoft/yii-runner](https://github.com/yiisoft/yii-runner)."
msgid "The incremental Yii3 option is [yiisoft/active-record](https://github.com/yiisoft/active-record):"
msgstr "[yiisoft/yii-runner](https://github.com/yiisoft/yii-runner) 的应用程序引导。"

#. type: Fenced code block (php)
#: ../src/guide/intro/upgrade-from-v1.md
#, no-wrap
msgid ""
"use Yiisoft\\ActiveRecord\\ActiveRecord;\n"
"\n"
"final class Post extends ActiveRecord\n"
"{\n"
"    protected int $id;\n"
"    protected string $title;\n"
"    protected string $body;\n"
"\n"
"    public function tableName(): string\n"
"    {\n"
"        return '{{%post}}';\n"
"    }\n"
"\n"
"    public function getTitle(): ?string\n"
"    {\n"
"        return $this->title ?? null;\n"
"    }\n"
"\n"
"    public function setTitle(string $title): void\n"
"    {\n"
"        $this->title = $title;\n"
"    }\n"
"}\n"
msgstr ""

#. type: Plain text
#: ../src/guide/intro/upgrade-from-v1.md
msgid "Move Yii 1.1 `rules()` to a form model, validator rules, or a service. Keep Active Record focused on persistence: table mapping, properties, relations, and database operations."
msgstr ""

#. type: Plain text
#: ../src/guide/intro/upgrade-from-v1.md
msgid "For more complex applications, consider replacing Active Record-heavy code with repositories and domain objects. That is more work initially, but it avoids carrying Yii 1.1 form and persistence coupling into the new application."
msgstr ""

