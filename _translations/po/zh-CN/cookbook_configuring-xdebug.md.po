#. type: Title ##
#: ../src/cookbook/configuring-xdebug.md
#, no-wrap
msgid "Debug tests"
msgstr ""

#. type: Plain text
#: ../src/cookbook/configuring-xdebug.md
msgid "Without Docker, start the test runner with an Xdebug trigger:"
msgstr ""

#. type: Fenced code block (shell)
#: ../src/cookbook/configuring-xdebug.md
#, no-wrap
msgid "XDEBUG_MODE=debug XDEBUG_SESSION=phpstorm vendor/bin/codecept run\n"
msgstr ""

#. type: Plain text
#: ../src/cookbook/configuring-xdebug.md
msgid "With Docker, configure `docker/test/override.env`:"
msgstr ""

#. type: Fenced code block (dotenv)
#: ../src/cookbook/configuring-xdebug.md
#, no-wrap
msgid ""
"XDEBUG_MODE=debug,coverage\n"
"XDEBUG_CONFIG=\"client_host=host.docker.internal idekey=phpstorm\"\n"
msgstr ""

#. type: Plain text
#: ../src/cookbook/configuring-xdebug.md
msgid "Then run the test container with a trigger:"
msgstr ""

#. type: Fenced code block (shell)
#: ../src/cookbook/configuring-xdebug.md
#, no-wrap
msgid ""
"docker compose -f docker/compose.yml -f docker/test/compose.yml run --rm \\\n"
"  -e XDEBUG_SESSION=phpstorm \\\n"
"  -e PHP_IDE_CONFIG=serverName=localhost \\\n"
"  app ./vendor/bin/codecept run\n"
msgstr ""

#. type: Plain text
#: ../src/cookbook/configuring-xdebug.md
msgid "Use `make test` for regular test runs. Use the explicit `docker compose` command when you need to pass debug-only environment variables to one run."
msgstr ""

