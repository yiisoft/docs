#. type: Plain text
#: ../src/guide/structure/designing-packages.md
msgid "Declare the group in `composer.json`:"
msgstr ""

#. type: Fenced code block (json)
#: ../src/guide/structure/designing-packages.md
#, no-wrap
msgid ""
"\"extra\": {\n"
"    \"config-plugin\": {\n"
"        \"di-providers\": \"config/di-providers.php\"\n"
"    }\n"
"}\n"
msgstr ""

#. type: Plain text
#: ../src/guide/structure/designing-packages.md
msgid "A provider can return several service definitions and extensions. Place the provider class in `src/Provider/BlogProvider.php`:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/structure/designing-packages.md
#, no-wrap
msgid ""
"<?php\n"
"\n"
"declare(strict_types=1);\n"
"\n"
"namespace Vendor\\Blog\\Provider;\n"
"\n"
"use Psr\\Container\\ContainerInterface;\n"
"use Psr\\Log\\LoggerInterface;\n"
"use Vendor\\Blog\\CachedPostRepository;\n"
"use Vendor\\Blog\\PostRepository;\n"
"use Vendor\\Blog\\PostRepositoryInterface;\n"
"use Yiisoft\\Di\\ServiceProviderInterface;\n"
"\n"
"final class BlogProvider implements ServiceProviderInterface\n"
"{\n"
"    public function getDefinitions(): array\n"
"    {\n"
"        return [\n"
"            PostRepository::class => PostRepository::class,\n"
"            PostRepositoryInterface::class => static fn (\n"
"                ContainerInterface $container\n"
"            ): CachedPostRepository => new CachedPostRepository(\n"
"                $container->get(PostRepository::class),\n"
"                $container->get(LoggerInterface::class),\n"
"            ),\n"
"        ];\n"
"    }\n"
"\n"
"    public function getExtensions(): array\n"
"    {\n"
"        return [];\n"
"    }\n"
"}\n"
msgstr ""

#. type: Plain text
#: ../src/guide/structure/designing-packages.md
msgid "Web packages can add routes through `config/routes.php`, declared as the `routes` group:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/structure/designing-packages.md
#, no-wrap
msgid ""
"<?php\n"
"\n"
"declare(strict_types=1);\n"
"\n"
"use Vendor\\Blog\\Web\\Post\\IndexAction;\n"
"use Yiisoft\\Router\\Group;\n"
"use Yiisoft\\Router\\Route;\n"
"\n"
"return [\n"
"    Group::create('/blog')->routes(\n"
"        Route::get('')\n"
"            ->action(IndexAction::class)\n"
"            ->name('vendor/blog/index'),\n"
"    ),\n"
"];\n"
msgstr ""

#. type: Plain text
#: ../src/guide/structure/designing-packages.md
msgid "Route names should be package-prefixed. This avoids collisions with application routes and with routes from other packages."
msgstr ""

#. type: Plain text
#: ../src/guide/structure/designing-packages.md
msgid "Keep package routes small and overridable. If an application needs full control over URLs, document the actions and let the application define its own routes."
msgstr ""

#. type: Plain text
#: ../src/guide/structure/designing-packages.md
msgid "Use `config/events.php`, `config/events-web.php`, or `config/events-console.php` to attach package handlers to events:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/structure/designing-packages.md
#, no-wrap
msgid ""
"<?php\n"
"\n"
"declare(strict_types=1);\n"
"\n"
"use Vendor\\Blog\\Event\\PostPublished;\n"
"use Vendor\\Blog\\EventHandler\\ClearPostListCache;\n"
"\n"
"return [\n"
"    PostPublished::class => [\n"
"        ClearPostListCache::class,\n"
"    ],\n"
"];\n"
msgstr ""

#. type: Plain text
#: ../src/guide/structure/designing-packages.md
msgid "Handlers can be closures, callables, invokable objects, invokable class names, or DI aliases supported by the event dispatcher configuration. Prefer class names for package handlers because applications can override their dependencies through the container."
msgstr ""

#. type: Title #
#: ../src/guide/structure/designing-packages.md ../src/guide/views/asset.md
#, no-wrap
msgid "Assets"
msgstr "资源"

#. type: Plain text
#: ../src/guide/structure/designing-packages.md
msgid "If your package ships CSS, JavaScript, images, or fonts, define asset bundles as PHP classes. For example, place this class in `src/Asset/BlogAsset.php`:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/structure/designing-packages.md
#, no-wrap
msgid ""
"<?php\n"
"\n"
"declare(strict_types=1);\n"
"\n"
"namespace Vendor\\Blog\\Asset;\n"
"\n"
"use Yiisoft\\Assets\\AssetBundle;\n"
"\n"
"final class BlogAsset extends AssetBundle\n"
"{\n"
"    public ?string $basePath = '@assets';\n"
"    public ?string $baseUrl = '@assetsUrl';\n"
"    public ?string $sourcePath = __DIR__ . '/../../assets';\n"
"\n"
"    public array $css = [\n"
"        'blog.css',\n"
"    ];\n"
"\n"
"    public array $js = [\n"
"        'blog.js',\n"
"    ];\n"
"}\n"
msgstr ""

#. type: Plain text
#: ../src/guide/structure/designing-packages.md
msgid "Users can register the bundle from a view, widget, view injection, or action:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/structure/designing-packages.md
#, no-wrap
msgid "$assetManager->register(BlogAsset::class);\n"
msgstr ""

#. type: Plain text
#: ../src/guide/structure/designing-packages.md
msgid "Use `$sourcePath` for files shipped inside the package. Use `$basePath` and `$baseUrl` as the public target where the asset manager publishes them."
msgstr ""

#. type: Plain text
#: ../src/guide/structure/designing-packages.md
msgid "Packages that need database schema changes should ship migrations and add their namespace or path to `yiisoft/db-migration` parameters."
