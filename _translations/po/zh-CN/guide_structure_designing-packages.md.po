#. type: Title ##
#: ../src/guide/structure/designing-packages.md
#, no-wrap
msgid "Themes"
msgstr ""

#. type: Plain text
#: ../src/guide/structure/designing-packages.md
msgid "A package can ship view files and assets for a theme. Do not activate it from vendor package configuration. Instead, document the root application configuration needed to enable it. For the application template, this belongs in `config/web/params.php`:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/structure/designing-packages.md
#, no-wrap
msgid ""
"<?php\n"
"\n"
"declare(strict_types=1);\n"
"\n"
"return [\n"
"    'yiisoft/view' => [\n"
"        'theme' => [\n"
"            'pathMap' => [\n"
"                '@views' => '@vendor/vendor/blog/views',\n"
"            ],\n"
"            'basePath' => '@vendor/vendor/blog/assets',\n"
"            'baseUrl' => '@assetsUrl/vendor-blog',\n"
"        ],\n"
"    ],\n"
"];\n"
msgstr ""

#. type: Plain text
#: ../src/guide/structure/designing-packages.md
msgid "Themes replace view paths according to a path map. Document which application view paths your theme replaces and which asset URL must be published or exposed by the application."
msgstr ""

#. type: Plain text
#: ../src/guide/structure/designing-packages.md
msgid "Do not set `yiisoft/view.theme` directly in vendor package configuration. `yiisoft/view` already defines that key, and duplicate keys in the same configuration layer are not allowed."
msgstr ""

#. type: Plain text
#: ../src/guide/structure/designing-packages.md
msgid "If your package only provides optional theme files, do not make the theme active by default. Provide the view files, asset bundle, and a documented parameter snippet so the application can opt in."
msgstr ""

#. type: Plain text
#: ../src/guide/structure/designing-packages.md
#, fuzzy
#| msgid "Add the command to `config/console/commands.php`:"
msgid "Console packages can add Symfony Console commands through `config/params-console.php`:"
msgstr "将命令添加到 `config/console/commands.php`："

#. type: Fenced code block (php)
#: ../src/guide/structure/designing-packages.md
#, no-wrap
