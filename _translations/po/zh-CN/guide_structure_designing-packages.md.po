"<?php\n"
"\n"
"declare(strict_types=1);\n"
"\n"
"use Vendor\\Blog\\Command\\ReindexCommand;\n"
"\n"
"return [\n"
"    'yiisoft/yii-console' => [\n"
"        'commands' => [\n"
"            'blog/reindex' => ReindexCommand::class,\n"
"        ],\n"
"    ],\n"
"];\n"
msgstr ""

#. type: Plain text
#: ../src/guide/structure/designing-packages.md
