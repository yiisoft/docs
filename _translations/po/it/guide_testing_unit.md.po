#. type: Title ##
#: ../src/guide/testing/unit.md
#, no-wrap
msgid "Add a unit test"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/unit.md
msgid "For example, create `src/Shared/SlugGenerator.php`:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/testing/unit.md
#, no-wrap
msgid ""
"<?php\n"
"\n"
"declare(strict_types=1);\n"
"\n"
"namespace App\\Shared;\n"
"\n"
"final class SlugGenerator\n"
"{\n"
"    public function generate(string $title): string\n"
"    {\n"
"        $slug = preg_replace('~[^a-z0-9]+~', '-', strtolower($title));\n"
"\n"
"        return trim((string) $slug, '-');\n"
"    }\n"
"}\n"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/unit.md
msgid "Create `tests/Unit/SlugGeneratorTest.php`:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/testing/unit.md
#, no-wrap
msgid ""
"<?php\n"
"\n"
"declare(strict_types=1);\n"
"\n"
"namespace App\\Tests\\Unit;\n"
"\n"
"use App\\Shared\\SlugGenerator;\n"
"use Codeception\\Test\\Unit;\n"
"\n"
"use function PHPUnit\\Framework\\assertSame;\n"
"\n"
"final class SlugGeneratorTest extends Unit\n"
"{\n"
"    public function testGenerateCreatesUrlFriendlySlug(): void\n"
"    {\n"
"        $generator = new SlugGenerator();\n"
"\n"
"        $slug = $generator->generate('Hello, Yii3!');\n"
"\n"
"        assertSame('hello-yii3', $slug);\n"
"    }\n"
"}\n"
msgstr ""

#. type: Fenced code block (shell)
#: ../src/guide/testing/unit.md
#, no-wrap
msgid "APP_ENV=test vendor/bin/codecept run Unit SlugGeneratorTest\n"
msgstr ""

