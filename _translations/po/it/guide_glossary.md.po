msgstr ""

#. type: Title ##
#: ../src/guide/glossary.md
#, no-wrap
msgid "service provider"
msgstr ""

#. type: Plain text
#: ../src/guide/glossary.md
msgid "Service provider is a class that registers related service definitions for the DI container.  Read more in [\"Service providers\"](concept/configuration.md#service-providers)."
msgstr ""

#. type: Title ##
#: ../src/guide/glossary.md
#, no-wrap
msgid "session"
msgstr ""

#. type: Plain text
#: ../src/guide/glossary.md
msgid "Session is server-side storage associated with a browser across multiple requests.  Read more in [\"Sessions\"](runtime/sessions.md)."
msgstr ""

