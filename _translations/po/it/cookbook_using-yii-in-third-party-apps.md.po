#. type: Title #
#: ../src/cookbook/using-yii-in-third-party-apps.md
#, no-wrap
msgid "Using Yii in third-party applications"
msgstr ""

#. type: Plain text
#: ../src/cookbook/using-yii-in-third-party-apps.md
msgid "Sometimes a project already has an entry point owned by another framework, CMS, or legacy application, but you still want to reuse Yii services: configuration, DI definitions, domain services, logging, mailers, database connections, or console-oriented application code."
msgstr ""

#. type: Plain text
#: ../src/cookbook/using-yii-in-third-party-apps.md
msgid "Yii3 has no global application singleton. Bootstrap the Yii container explicitly and pass the services you need to the third-party code."
msgstr ""

#. type: Title ##
#: ../src/cookbook/using-yii-in-third-party-apps.md
#, fuzzy, no-wrap
#| msgid "[Configuration](concept/configuration.md)"
msgid "Bootstrap the Yii container"
msgstr "[Configurazione](concept/configuration.md)"

#. type: Plain text
#: ../src/cookbook/using-yii-in-third-party-apps.md
msgid "Create a small adapter in the host application, for example `bootstrap-yii-services.php`:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/cookbook/using-yii-in-third-party-apps.md
#, no-wrap
msgid ""
"<?php\n"
"\n"
"declare(strict_types=1);\n"
"\n"
"use App\\Environment;\n"
"use Psr\\Container\\ContainerInterface;\n"
"use Yiisoft\\Config\\Config;\n"
"use Yiisoft\\Config\\ConfigInterface;\n"
"use Yiisoft\\Config\\ConfigPaths;\n"
"use Yiisoft\\Config\\Modifier\\RecursiveMerge;\n"
"use Yiisoft\\Config\\Modifier\\ReverseMerge;\n"
"use Yiisoft\\Di\\Container;\n"
"use Yiisoft\\Di\\ContainerConfig;\n"
"\n"
"function yiiContainer(string $yiiRoot): ContainerInterface\n"
"{\n"
"    require_once $yiiRoot . '/src/bootstrap.php';\n"
"\n"
"    $paramsGroup = 'params-console';\n"
"    $eventsGroups = ['events-console', 'events'];\n"
"\n"
"    $config = new Config(\n"
"        paths: new ConfigPaths($yiiRoot, 'config', 'vendor'),\n"
"        environment: Environment::appEnv(),\n"
"        modifiers: [\n"
"            ReverseMerge::groups(...$eventsGroups),\n"
"            RecursiveMerge::groups($paramsGroup, 'params', ...$eventsGroups),\n"
"        ],\n"
"        paramsGroup: $paramsGroup,\n"
"    );\n"
"\n"
"    $containerConfig = ContainerConfig::create()\n"
"        ->withValidate(Environment::appDebug())\n"
"        ->withDefinitions(array_merge(\n"
"            $config->get('di-console'),\n"
"            [ConfigInterface::class => $config],\n"
"        ))\n"
"        ->withProviders($config->get('di-providers-console'))\n"
"        ->withDelegates($config->get('di-delegates-console'));\n"
"\n"
"    if ($config->has('di-tags-console')) {\n"
"        $containerConfig = $containerConfig->withTags($config->get('di-tags-console'));\n"
"    }\n"
"\n"
"    $container = new Container($containerConfig);\n"
"\n"
"    foreach ($config->get('bootstrap-console') as $callback) {\n"
"        if (!is_callable($callback)) {\n"
"            throw new RuntimeException(sprintf(\n"
"                'Bootstrap callback must be callable, \"%s\" given.',\n"
"                get_debug_type($callback),\n"
"            ));\n"
"        }\n"
"\n"
"        $callback($container);\n"
"    }\n"
"\n"
"    return $container;\n"
"}\n"
msgstr ""

#. type: Plain text
#: ../src/cookbook/using-yii-in-third-party-apps.md
msgid "The adapter builds only the Yii configuration and DI container, then runs the configured bootstrap callbacks. It does not create or run a Yii application runner, so the third-party application keeps ownership of the entry point and process lifecycle."
msgstr ""

#. type: Plain text
#: ../src/cookbook/using-yii-in-third-party-apps.md
msgid "Use console configuration groups when you need common services and console-safe services. Use web groups instead only when you intentionally need web-specific definitions from the `di-web` group, such as PSR-17 HTTP factories or web middleware dependencies."
msgstr ""

#. type: Title ##
#: ../src/cookbook/using-yii-in-third-party-apps.md
#, no-wrap
msgid "Get Yii services from the host application"
msgstr ""

#. type: Plain text
#: ../src/cookbook/using-yii-in-third-party-apps.md
msgid "Use the adapter from the third-party application:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/cookbook/using-yii-in-third-party-apps.md
#, no-wrap
msgid ""
"<?php\n"
"\n"
"declare(strict_types=1);\n"
"\n"
"use App\\Shared\\ApplicationParams;\n"
"\n"
"require_once __DIR__ . '/path/to/yii-app/vendor/autoload.php';\n"
"require_once __DIR__ . '/bootstrap-yii-services.php';\n"
"\n"
"$container = yiiContainer(__DIR__ . '/path/to/yii-app');\n"
"\n"
"/** @var ApplicationParams $params */\n"
"$params = $container->get(ApplicationParams::class);\n"
"\n"
"echo $params->name;\n"
msgstr ""

#. type: Plain text
#: ../src/cookbook/using-yii-in-third-party-apps.md
msgid "In real integrations, prefer getting your own application services instead of framework infrastructure. For example, expose `InvoiceSender`, `ReportBuilder`, or `CatalogImporter` from Yii and call that service from the host application."
msgstr ""

#. type: Title ##
#: ../src/cookbook/using-yii-in-third-party-apps.md
#, no-wrap
msgid "Keep boundaries explicit"
msgstr ""

#. type: Plain text
#: ../src/cookbook/using-yii-in-third-party-apps.md
msgid "Avoid mixing request lifecycles. Let the host application continue to own its HTTP request and response. Let Yii provide services that do not assume Yii is handling the current request."
msgstr ""

