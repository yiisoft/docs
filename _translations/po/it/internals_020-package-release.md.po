msgid "Close to 100% test coverage with, ideally, a 100% MSI score."
msgstr ""

#. type: Bullet: '- '
#: ../src/internals/020-package-release.md
msgid "README is alright."
msgstr ""

#. type: Bullet: '- '
#: ../src/internals/020-package-release.md
msgid "Everything is type-hinted unless special cases."
msgstr ""

#. type: Bullet: '- '
#: ../src/internals/020-package-release.md
