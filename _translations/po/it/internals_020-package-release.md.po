#. type: Title ##
#: ../src/internals/020-package-release.md
#, no-wrap
msgid "Release branch policy"
msgstr ""

#. type: Plain text
#: ../src/internals/020-package-release.md
msgid "Use `master` for all regular releases."
msgstr ""

#. type: Plain text
#: ../src/internals/020-package-release.md
msgid "Create a separate branch only when releasing a new version for a previous major version. In this case, create the branch from the latest tag in that previous major version line and apply only the changes needed for the release."
msgstr ""

#. type: Title ##
#: ../src/internals/020-package-release.md
#, no-wrap
msgid "Release instruction"
msgstr ""

#. type: Plain text
#: ../src/internals/020-package-release.md
msgid "Release a package via [Yii Development Tool](005-development-tool.md)."
msgstr ""

#. type: Plain text
#: ../src/internals/020-package-release.md
#, no-wrap
msgid ""
"1. Check that you can sign commits locally (see \n"
"[Signing commits](https://docs.github.com/en/authentication/managing-commit-signature-verification/signing-commits)).\n"
msgstr ""

#. type: Bullet: '2. '
#: ../src/internals/020-package-release.md
msgid "For regular releases, pull last changes from the `master` branch:"
msgstr ""

#. type: Fenced code block (shell)
#: ../src/internals/020-package-release.md
#, no-wrap
msgid ""
"./yii-dev git/checkout master package-name\n"
"./yii-dev git/pull package-name\n"
msgstr ""

#. type: Plain text
#: ../src/internals/020-package-release.md
msgid "For previous major version releases, use the branch created according to the release branch policy instead of `master`."
msgstr ""

#. type: Bullet: '3. '
#: ../src/internals/020-package-release.md
msgid "Check the package for compliance with the criteria above."
msgstr ""

#. type: Bullet: '4. '
#: ../src/internals/020-package-release.md
msgid "Run `release/make` command:"
msgstr ""

#. type: Fenced code block (shell)
#: ../src/internals/020-package-release.md
#, no-wrap
msgid "./yii-dev release/make package-name\n"
msgstr ""

#. type: Bullet: '5. '
#: ../src/internals/020-package-release.md
msgid "Select the version type (major, minor or patch)."
msgstr ""

#. type: Bullet: '6. '
#: ../src/internals/020-package-release.md
msgid "On the question \"Push commits and tags, and release on GitHub?\" check a diff. If the diff is alright, answer \"yes.\""
msgstr ""

#. type: Bullet: '7. '
#: ../src/internals/020-package-release.md
msgid "For major and minor releases, add a record with release notes on [Yii Framework News](https://www.yiiframework.com/news)."
msgstr ""
