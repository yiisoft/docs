#. type: Plain text
#: ../src/cookbook/custom-migration-template.md
msgid "To replace multiple templates at once, use `setTemplates()`:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/cookbook/custom-migration-template.md
#, no-wrap
msgid ""
"use Yiisoft\\Db\\Migration\\Service\\Generate\\CreateService;\n"
"\n"
"return [\n"
"    CreateService::class => [\n"
"        'setTemplates()' => [[\n"
"            'create' => dirname(__DIR__, 3) . '/resources/migration-templates/migration.php',\n"
"            'table' => dirname(__DIR__, 3) . '/resources/migration-templates/create-table.php',\n"
"            'dropTable' => dirname(__DIR__, 3) . '/resources/migration-templates/drop-table.php',\n"
"            'addColumn' => dirname(__DIR__, 3) . '/resources/migration-templates/add-column.php',\n"
"            'dropColumn' => dirname(__DIR__, 3) . '/resources/migration-templates/drop-column.php',\n"
"            'junction' => dirname(__DIR__, 3) . '/resources/migration-templates/create-junction.php',\n"
"        ]],\n"
"    ],\n"
"];\n"
msgstr ""

#. type: Plain text
#: ../src/cookbook/custom-migration-template.md
msgid "For table-oriented templates, copy the corresponding file from `vendor/yiisoft/db-migration/resources/views/` and adjust it. Those templates receive additional variables such as `$table`, `$columns`, `$foreignKeys`, and `$tableComment`."
msgstr ""

#. type: Title ##
#: ../src/cookbook/custom-migration-template.md
#, no-wrap
msgid "Keep templates maintainable"
msgstr ""

#. type: Plain text
#: ../src/cookbook/custom-migration-template.md
msgid "Keep generated migrations independent from current application services. A migration may run years later, after service APIs have changed. Put stable schema operations in the generated class and leave business logic in console commands or application services."
msgstr ""

#. type: Plain text
#: ../src/cookbook/custom-migration-template.md
msgid "Do not edit templates under `vendor/`. Copy them into your project and configure `CreateService` to use the copies."
msgstr ""
