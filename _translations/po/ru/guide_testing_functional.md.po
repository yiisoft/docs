"APP_ENV=test vendor/bin/codecept run Functional HomePageCest\n"
msgstr ""

#. type: Title ##
#: ../src/guide/testing/functional.md
#, no-wrap
msgid "Send request data"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/functional.md
msgid "Use PSR-7 methods to model the request:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/testing/functional.md
#, no-wrap
msgid ""
"$request = (new ServerRequest(uri: '/contact', method: 'POST'))\n"
"    ->withHeader('Content-Type', 'application/x-www-form-urlencoded')\n"
"    ->withParsedBody([\n"
"        'ContactForm' => [\n"
"            'name' => 'Sam',\n"
"            'email' => 'sam@example.test',\n"
"            'body' => 'Hello.',\n"
"        ],\n"
"    ]);\n"
"\n"
"$response = $tester->sendRequest($request);\n"
"\n"
"assertSame(302, $response->getStatusCode());\n"
"assertSame('/contact/sent', $response->getHeaderLine('Location'));\n"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/functional.md
msgid "For JSON APIs, write the JSON body into a PSR-7 stream and set `Content-Type: application/json`."
msgstr ""

