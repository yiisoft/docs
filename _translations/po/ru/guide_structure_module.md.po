#. type: Title ##
#: ../src/guide/structure/module.md
#, fuzzy, no-wrap
msgid "Cross-module communication"
msgstr "Безопасная конфигурация сервера"

#. type: Plain text
#: ../src/guide/structure/module.md
msgid "Choose the smallest coupling that supports the behavior:"
msgstr ""

#. type: Bullet: '- '
#: ../src/guide/structure/module.md
msgid "Use constructor injection with an interface for a direct synchronous call."
msgstr ""

#. type: Bullet: '- '
#: ../src/guide/structure/module.md
msgid "Use an event when the producer should not know who reacts to something that happened."
msgstr ""

#. type: Bullet: '- '
#: ../src/guide/structure/module.md
msgid "Use an application service or use case class when orchestration belongs outside both modules."
msgstr ""

#. type: Bullet: '- '
#: ../src/guide/structure/module.md
msgid "Use a package when the module must be reused by more than one application."
msgstr ""

#. type: Plain text
#: ../src/guide/structure/module.md
msgid "Avoid service locator calls and global state inside module classes. Let actions, commands, and services receive their dependencies through constructors so module boundaries stay visible in code and testable in isolation."
msgstr ""
