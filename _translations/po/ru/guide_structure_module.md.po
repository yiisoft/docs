#. type: Fenced code block
#: ../src/guide/structure/module.md
#, no-wrap
msgid ""
"config/\n"
"    common/\n"
"        di/\n"
"            blog.php\n"
"        routes/\n"
"            blog.php\n"
"        params.php\n"
"    console/\n"
"        params.php\n"
"    web/\n"
"        params.php\n"
msgstr ""

#. type: Plain text
#: ../src/guide/structure/module.md
msgid "Put shared service definitions in `common/di/`. Put web-only definitions in `web/di/`. Put console-only parameters or command registrations in `console/params.php`."
msgstr ""

#. type: Plain text
#: ../src/guide/structure/module.md
