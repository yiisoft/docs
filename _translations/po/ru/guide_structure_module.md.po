msgid "Application modules use the same configuration groups as packages. The difference is where the configuration lives:"
msgstr ""

#. type: Bullet: '- '
#: ../src/guide/structure/module.md
msgid "application module configuration lives in the root application under `config/`;"
msgstr ""

#. type: Bullet: '- '
#: ../src/guide/structure/module.md
msgid "package module configuration lives in the package and is declared in `extra.config-plugin`."
msgstr ""

#. type: Plain text
#: ../src/guide/structure/module.md
#, fuzzy
#| msgid "You can define an alias via application's `config/params.php`:"
