msgid "Choose a suite"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/overview.md
msgid "Start with unit tests for code that has no framework boundary: value objects, validators, domain services, and transformers."
msgstr ""

#. type: Plain text
#: ../src/guide/testing/overview.md
msgid "Use functional tests when code needs Yii configuration, dependency injection, routing, middleware, request handling, or template rendering."
msgstr ""

#. type: Plain text
#: ../src/guide/testing/overview.md
msgid "Use web tests for behavior that must go through an HTTP server: status codes, links, redirects, cookies, and rendered pages as seen by a client."
msgstr ""

#. type: Plain text
#: ../src/guide/testing/overview.md
msgid "Use console tests for commands in `src/Console`."
msgstr ""

#. type: Plain text
#: ../src/guide/testing/overview.md
msgid "Run static analysis in CI and before changing shared contracts."
msgstr ""
