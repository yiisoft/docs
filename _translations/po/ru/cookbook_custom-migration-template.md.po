#. type: Plain text
#: ../src/cookbook/custom-migration-template.md
msgid "The `migrate:create` command from `yiisoft/db-migration` generates migration classes from PHP view templates. Use a custom template when your project wants a standard header, strict class shape, comments, helper calls, or team-specific placeholders in every new migration."
msgstr ""

#. type: Plain text
#: ../src/cookbook/custom-migration-template.md
msgid "This recipe assumes migrations are already configured as described in the [Database migrations](../guide/databases/db-migrations.md) guide."
msgstr ""

#. type: Title ##
#: ../src/cookbook/custom-migration-template.md
#, fuzzy, no-wrap
#| msgid "Create a page."
msgid "Create a template"
msgstr "Создать страницу."

#. type: Plain text
#: ../src/cookbook/custom-migration-template.md
#, fuzzy
#| msgid "Create `src/Web/Page/PageRepository.php`:"
msgid "Create `resources/migration-templates/migration.php`:"
msgstr "Создайте файл `src/Web/Page/PageRepository.php`:"

#. type: Fenced code block (php)
#: ../src/cookbook/custom-migration-template.md
#, no-wrap
msgid ""
"<?php\n"
"\n"
"declare(strict_types=1);\n"
"\n"
"/**\n"
" * This view is used by {@see Yiisoft\\Db\\Migration\\Command\\CreateCommand}.\n"
" *\n"
" * @var \\Yiisoft\\Db\\Migration\\Service\\Generate\\PhpRenderer $this\n"
" * @var string $className The new migration class name without namespace.\n"
" * @var string $namespace The new migration class namespace.\n"
" */\n"
"\n"
"echo \"<?php\\n\";\n"
"echo \"\\ndeclare(strict_types=1);\\n\";\n"
"\n"
"if (!empty($namespace)) {\n"
"    echo \"\\nnamespace {$namespace};\\n\";\n"
"}\n"
"?>\n"
"\n"
"use Yiisoft\\Db\\Migration\\MigrationBuilder;\n"
"use Yiisoft\\Db\\Migration\\RevertibleMigrationInterface;\n"
"\n"
"final class <?= $className ?> implements RevertibleMigrationInterface\n"
"{\n"
"    public function up(MigrationBuilder $b): void\n"
"    {\n"
"        // Add forward migration code.\n"
"    }\n"
"\n"
"    public function down(MigrationBuilder $b): void\n"
"    {\n"
"        // Add rollback migration code.\n"
"    }\n"
"}\n"
msgstr ""

#. type: Plain text
#: ../src/cookbook/custom-migration-template.md
msgid "The template is a PHP file that prints the generated migration. For the default `create` command, the most useful variables are `$className` and `$namespace`."
msgstr ""

#. type: Title ##
#: ../src/cookbook/custom-migration-template.md
#, fuzzy, no-wrap
#| msgid "Confirming data integrity"
msgid "Configure the generator"
msgstr "Проверка целостности данных"

#. type: Plain text
#: ../src/cookbook/custom-migration-template.md
#, fuzzy
#| msgid "Now create `config/common/di/db-pgsql.php`:"
msgid "Create `config/common/di/migration-generator.php`:"
msgstr "Теперь создайте файл `config/common/di/db-pgsql.php`:"

#. type: Fenced code block (php)
#: ../src/cookbook/custom-migration-template.md
#, no-wrap
msgid ""
"<?php\n"
"\n"
"declare(strict_types=1);\n"
"\n"
"use Yiisoft\\Db\\Migration\\Service\\Generate\\CreateService;\n"
"\n"
"return [\n"
"    CreateService::class => [\n"
"        'setTemplate()' => [\n"
"            'create',\n"
"            dirname(__DIR__, 3) . '/resources/migration-templates/migration.php',\n"
"        ],\n"
"    ],\n"
"];\n"
msgstr ""

