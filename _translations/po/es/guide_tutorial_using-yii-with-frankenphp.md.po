#. type: Title #
#: ../src/guide/tutorial/using-yii-with-frankenphp.md
#, no-wrap
msgid "Using Yii with FrankenPHP"
msgstr ""

#. type: Plain text
#: ../src/guide/tutorial/using-yii-with-frankenphp.md
#, no-wrap
msgid ""
"[FrankenPHP](https://frankenphp.dev/) is an application server for PHP with Caddy built in. It can run Yii in \n"
"[worker mode](using-with-event-loop.md), allowing the framework bootstrap to happen once per worker instead of\n"
"once per request.\n"
msgstr ""

#. type: Plain text
#: ../src/guide/tutorial/using-yii-with-frankenphp.md
msgid "Install the FrankenPHP runner package with Composer:"
msgstr ""

#. type: Fenced code block (shell)
#: ../src/guide/tutorial/using-yii-with-frankenphp.md
#, no-wrap
msgid "composer require yiisoft/yii-runner-frankenphp\n"
msgstr ""

#. type: Plain text
#: ../src/guide/tutorial/using-yii-with-frankenphp.md
msgid "FrankenPHP works especially well in containerized deployments and is the runtime used by the Yii application templates Docker setup described in [Docker in application templates](docker.md)."
msgstr ""

#. type: Plain text
#: ../src/guide/tutorial/using-yii-with-frankenphp.md
msgid "First, configure the worker entry script."
msgstr ""

#. type: Title ###
#: ../src/guide/tutorial/using-yii-with-frankenphp.md
#, no-wrap
msgid "Worker entry script"
msgstr ""

#. type: Plain text
#: ../src/guide/tutorial/using-yii-with-frankenphp.md
msgid "Create `/worker.php` in the project root:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/tutorial/using-yii-with-frankenphp.md
#, no-wrap
msgid ""
"<?php\n"
"\n"
"declare(strict_types=1);\n"
"\n"
"use App\\Environment;\n"
"use Psr\\Log\\LogLevel;\n"
"use Yiisoft\\ErrorHandler\\ErrorHandler;\n"
"use Yiisoft\\ErrorHandler\\Renderer\\PlainTextRenderer;\n"
"use Yiisoft\\Log\\Logger;\n"
"use Yiisoft\\Log\\StreamTarget;\n"
"use Yiisoft\\Yii\\Runner\\FrankenPHP\\FrankenPHPApplicationRunner;\n"
"\n"
"$root = __DIR__;\n"
"\n"
"require_once $root . '/src/bootstrap.php';\n"
"\n"
"if (Environment::appC3()) {\n"
"    $c3 = $root . '/c3.php';\n"
"    if (file_exists($c3)) {\n"
"        require_once $c3;\n"
"    }\n"
"}\n"
"\n"
"$runner = new FrankenPHPApplicationRunner(\n"
"    rootPath: $root,\n"
"    debug: Environment::appDebug(),\n"
"    checkEvents: Environment::appDebug(),\n"
"    environment: Environment::appEnv(),\n"
"    temporaryErrorHandler: new ErrorHandler(\n"
"        new Logger(\n"
"            [\n"
"                (new StreamTarget())->setLevels([\n"
"                    LogLevel::EMERGENCY,\n"
"                    LogLevel::ERROR,\n"
"                    LogLevel::WARNING,\n"
"                ]),\n"
"            ],\n"
"        ),\n"
"        new PlainTextRenderer(),\n"
"    ),\n"
");\n"
"$runner->run();\n"
msgstr ""

#. type: Plain text
#: ../src/guide/tutorial/using-yii-with-frankenphp.md
msgid "The runner bootstraps the application once and then keeps processing requests in worker mode. Unlike classic `public/index.php`, this script is not executed per request."
msgstr ""

#. type: Title ###
#: ../src/guide/tutorial/using-yii-with-frankenphp.md
#, fuzzy, no-wrap
#| msgid "Introduction +"
msgid "Server configuration"
msgstr "Introducción"

#. type: Plain text
#: ../src/guide/tutorial/using-yii-with-frankenphp.md
msgid "FrankenPHP is configured through a `Caddyfile`. For production, it may look like the following:"
msgstr ""

#. type: Fenced code block (caddyfile)
#: ../src/guide/tutorial/using-yii-with-frankenphp.md
#, no-wrap
msgid ""
"{\n"
"    skip_install_trust\n"
"\n"
"    frankenphp {\n"
"\n"
"    }\n"
"}\n"
"\n"
"{$SERVER_NAME::80} {\n"
"    encode zstd br gzip\n"
"    php_server {\n"
"        root /app/public\n"
"        worker {\n"
"            match *\n"
"            file /app/worker.php\n"
"        }\n"
"    }\n"
"}\n"
msgstr ""

#. type: Plain text
#: ../src/guide/tutorial/using-yii-with-frankenphp.md
msgid "This configuration tells FrankenPHP to serve the `public` directory and handle all requests with `worker.php`.  Static assets are still served from `public`, while PHP requests are processed through the long-running worker."
msgstr ""

#. type: Plain text
#: ../src/guide/tutorial/using-yii-with-frankenphp.md
msgid "For development, add `watch` so FrankenPHP reloads workers when PHP files change:"
msgstr ""

#. type: Fenced code block (caddyfile)
#: ../src/guide/tutorial/using-yii-with-frankenphp.md
#, no-wrap
msgid ""
"{\n"
"    skip_install_trust\n"
"\n"
"    frankenphp {\n"
"\n"
"    }\n"
"}\n"
"\n"
"{$SERVER_NAME::80} {\n"
"    encode zstd br gzip\n"
"    php_server {\n"
"        root /app/public\n"
"        worker {\n"
"            match *\n"
"            file /app/worker.php\n"
"            watch /app/**/*.php\n"
"        }\n"
"    }\n"
"}\n"
msgstr ""

#. type: Title ###
#: ../src/guide/tutorial/using-yii-with-frankenphp.md
#, no-wrap
