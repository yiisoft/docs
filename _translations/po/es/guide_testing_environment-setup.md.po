#. type: Plain text
#: ../src/guide/testing/environment-setup.md
msgid "The Yii application template has the test environment configured. Use this page when creating a new project from the template, restoring removed test files, or adding a new suite."
msgstr ""

#. type: Title ##
#: ../src/guide/testing/environment-setup.md
#, fuzzy, no-wrap
#| msgid "Introduction +"
msgid "Composer configuration"
msgstr "Introducción"

#. type: Plain text
#: ../src/guide/testing/environment-setup.md
msgid "The template requires Codeception, PHPUnit, and the modules used by the suites:"
msgstr ""

#. type: Fenced code block (json)
#: ../src/guide/testing/environment-setup.md
#, no-wrap
msgid ""
"{\n"
"  \"require-dev\": {\n"
"    \"codeception/codeception\": \"^5.3\",\n"
"    \"codeception/module-asserts\": \"^3.2\",\n"
"    \"codeception/module-cli\": \"^2.0\",\n"
"    \"codeception/module-phpbrowser\": \"^3.0\",\n"
"    \"phpunit/phpunit\": \"^11.5\"\n"
"  },\n"
"  \"autoload-dev\": {\n"
"    \"psr-4\": {\n"
"      \"App\\\\Tests\\\\\": \"tests\"\n"
"    }\n"
"  },\n"
"  \"scripts\": {\n"
"    \"test\": \"codecept run\"\n"
"  }\n"
"}\n"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/environment-setup.md
msgid "If these entries are already in your project, keep the installed versions from `composer.lock`."
msgstr ""

#. type: Title ##
#: ../src/guide/testing/environment-setup.md
#, no-wrap
msgid "Main Codeception file"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/environment-setup.md
msgid "The root `codeception.yml` defines the test namespace, paths, bootstrap file, and coverage source:"
msgstr ""

#. type: Fenced code block (yaml)
#: ../src/guide/testing/environment-setup.md
#, no-wrap
msgid ""
"namespace: App\\Tests\n"
"support_namespace: Support\n"
"bootstrap: bootstrap.php\n"
"\n"
"settings:\n"
"  shuffle: true\n"
"  colors: true\n"
"\n"
"paths:\n"
"  tests: tests\n"
"  output: tests/_output\n"
"  data: tests/Support/Data\n"
"  support: tests/Support\n"
"\n"
"coverage:\n"
"  enabled: true\n"
"  show_uncovered: true\n"
"  show_only_summary: true\n"
"  include:\n"
"    - src/*\n"
"    - public/index.php\n"
"    - yii\n"
"\n"
"extensions:\n"
"  enabled:\n"
"    - Codeception\\Extension\\RunFailed\n"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/environment-setup.md
msgid "`tests/bootstrap.php` prepares the application environment for every suite:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/testing/environment-setup.md
#, no-wrap
msgid ""
"<?php\n"
"\n"
"declare(strict_types=1);\n"
"\n"
"App\\Environment::prepare();\n"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/environment-setup.md
msgid "Set `APP_ENV=test` when running tests locally:"
msgstr ""

#. type: Fenced code block (shell)
#: ../src/guide/testing/environment-setup.md ../src/guide/testing/overview.md
#, no-wrap
msgid "APP_ENV=test vendor/bin/codecept run\n"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/environment-setup.md
msgid "The Docker test service reads the same value from `docker/test/.env`:"
msgstr ""

#. type: Fenced code block (dotenv)
#: ../src/guide/testing/environment-setup.md
#, no-wrap
msgid ""
"APP_ENV=test\n"
"APP_DEBUG=false\n"
"APP_C3=true\n"
"SERVER_NAME=:80\n"
"XDEBUG_MODE=coverage\n"
"COMPOSER_CACHE_DIR=/app/runtime/cache/composer\n"
msgstr ""

#. type: Title ##
#: ../src/guide/testing/environment-setup.md
#, no-wrap
msgid "Suites"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/environment-setup.md
msgid "The template has one suite file per test type."
msgstr ""

#. type: Plain text
#: ../src/guide/testing/environment-setup.md
msgid "`tests/Unit.suite.yml` enables PHPUnit assertions through Codeception:"
msgstr ""

#. type: Fenced code block (yaml)
#: ../src/guide/testing/environment-setup.md
#, no-wrap
msgid ""
"actor: UnitTester\n"
"modules:\n"
"    enabled:\n"
"        - Asserts\n"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/environment-setup.md
msgid "`tests/Functional.suite.yml` uses the project `FunctionalTester` helper:"
msgstr ""

#. type: Fenced code block (yaml)
#: ../src/guide/testing/environment-setup.md
#, no-wrap
msgid "actor: FunctionalTester\n"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/environment-setup.md
msgid "`tests/Web.suite.yml` starts the built-in server and sends HTTP requests with PhpBrowser:"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/environment-setup.md
msgid "`tests/Console.suite.yml` enables console command testing:"
msgstr ""

#. type: Fenced code block (yaml)
#: ../src/guide/testing/environment-setup.md
#, no-wrap
msgid ""
"actor: ConsoleTester\n"
"modules:\n"
"  enabled:\n"
"    - Cli\n"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/environment-setup.md
msgid "After adding or changing a suite, rebuild generated actor actions:"
msgstr ""

#. type: Fenced code block (shell)
#: ../src/guide/testing/environment-setup.md ../src/guide/testing/overview.md
#, no-wrap
msgid "vendor/bin/codecept build\n"
msgstr ""

#. type: Fenced code block (shell)
#: ../src/guide/testing/environment-setup.md ../src/guide/testing/overview.md
#, no-wrap
msgid "make codecept build\n"
msgstr ""

