#. type: Title #
#: ../src/guide/structure/package.md
#, no-wrap
msgid "Using packages"
msgstr ""

#. type: Plain text
#: ../src/guide/structure/package.md
msgid "Reusable code is distributed as [Composer packages](https://getcomposer.org/doc/05-repositories.md#package).  A package can be an infrastructure library, a Yii integration, a reusable feature, or a module representing an application context."
msgstr ""

#. type: Plain text
#: ../src/guide/structure/package.md
msgid "This page explains how to use packages in an application. To create a Yii-aware package, see [Designing packages for Yii applications](designing-packages.md)."
msgstr ""

#. type: Title ##
#: ../src/guide/structure/package.md
#, fuzzy, no-wrap
#| msgid "Resolving aliases <span id=\"resolving-aliases\"></span>"
msgid "Installing packages <span id=\"installing-packages\"></span>"
msgstr "Resolución de Alias <span id=\"resolving-aliases\"></span>"

#. type: Plain text
#: ../src/guide/structure/package.md
msgid "By default, Composer installs packages registered on [Packagist](https://packagist.org/), the main repository for open source PHP packages."
msgstr ""

#. type: Plain text
#: ../src/guide/structure/package.md
msgid "Install a package with:"
msgstr ""

#. type: Fenced code block (sh)
#: ../src/guide/structure/package.md
#, no-wrap
msgid "composer require vendor-name/package-name\n"
msgstr ""

#. type: Plain text
#: ../src/guide/structure/package.md
msgid "Composer updates two files:"
msgstr ""

#. type: Bullet: '- '
#: ../src/guide/structure/package.md
msgid "`composer.json` stores the package name and version constraint."
msgstr ""

#. type: Bullet: '- '
#: ../src/guide/structure/package.md
msgid "`composer.lock` stores the exact versions installed."
msgstr ""

#. type: Plain text
#: ../src/guide/structure/package.md
msgid "Commit both files so other environments install the same dependency versions."
msgstr ""

#. type: Plain text
#: ../src/guide/structure/package.md
msgid "Installed packages are stored in the application `vendor/` directory."
msgstr ""

#. type: Plain text
#: ../src/guide/structure/package.md
#, no-wrap
msgid ""
"> [!WARNING]\n"
"> Never edit files in `vendor/` directly. Change application configuration, extend classes, decorate services, or\n"
"> contribute fixes to the package instead.\n"
msgstr ""

#. type: Plain text
#: ../src/guide/structure/package.md
msgid "Package classes are available through Composer autoloading after installation. See [Autoloading](../concept/autoloading.md)  for details."
msgstr ""

#. type: Title ##
#: ../src/guide/structure/package.md
#, fuzzy, no-wrap
#| msgid "Defining aliases <span id=\"defining-aliases\"></span>"
msgid "Updating packages <span id=\"updating-packages\"></span>"
msgstr "Definir Alias <span id=\"defining-aliases\"></span>"

#. type: Plain text
#: ../src/guide/structure/package.md
msgid "Update a package within the version constraint recorded in `composer.json`:"
msgstr ""

#. type: Fenced code block (sh)
#: ../src/guide/structure/package.md
#, no-wrap
msgid "composer update vendor-name/package-name\n"
msgstr ""

#. type: Plain text
#: ../src/guide/structure/package.md
msgid "Change the accepted version constraint with `composer require`:"
msgstr ""

#. type: Fenced code block (sh)
#: ../src/guide/structure/package.md
#, no-wrap
msgid "composer require vendor-name/package-name:^2.0\n"
msgstr ""

#. type: Plain text
#: ../src/guide/structure/package.md
msgid "After updating a Yii-aware package, Composer rebuilds Yii's configuration merge plan. If you changed configuration group mappings manually, rebuild it explicitly:"
msgstr ""

#. type: Title ##
#: ../src/guide/structure/package.md
#, fuzzy, no-wrap
#| msgid "Resolving aliases <span id=\"resolving-aliases\"></span>"
msgid "Removing packages <span id=\"removing-packages\"></span>"
