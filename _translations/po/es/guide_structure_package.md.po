#. type: Plain text
#: ../src/guide/structure/package.md
msgid "For private code, configure Composer repositories in the application `composer.json`. Common options are:"
msgstr ""

#. type: Bullet: '- '
#: ../src/guide/structure/package.md
msgid "`vcs` for a Git repository."
msgstr ""

#. type: Bullet: '- '
#: ../src/guide/structure/package.md
msgid "`path` for a local package during development."
msgstr ""

#. type: Bullet: '- '
#: ../src/guide/structure/package.md
msgid "`composer` for a private Composer repository."
msgstr ""

