#. type: Plain text
#: ../src/guide/structure/package.md
msgid "Remove a package with:"
msgstr ""

#. type: Fenced code block (sh)
#: ../src/guide/structure/package.md
#, no-wrap
msgid "composer remove vendor-name/package-name\n"
msgstr ""

#. type: Plain text
#: ../src/guide/structure/package.md
msgid "Then remove application code and configuration that referenced classes, services, routes, commands, assets, migrations, or translations from that package."
msgstr ""

