#. type: Title ###
#: ../src/guide/tutorial/docker.md
#, no-wrap
msgid "docker/compose.yml (base)"
msgstr ""

#. type: Plain text
#: ../src/guide/tutorial/docker.md
msgid "The base file defines shared settings inherited by all environments:"
