#. type: Title ##
#: ../src/guide/tutorial/docker.md
#, no-wrap
msgid "Docker directory overview"
msgstr ""

#. type: Plain text
#: ../src/guide/tutorial/docker.md
msgid "All Docker-related files live under the `docker/` directory:"
msgstr ""

#. type: Fenced code block
#: ../src/guide/tutorial/docker.md
#, no-wrap
msgid ""
"docker/\n"
"├── .env                  # Compose-level variables (stack name, ports, image names)\n"
"├── Dockerfile            # Multi-stage image definition\n"
"├── compose.yml           # Base Compose file (shared anchor for all environments)\n"
"├── dev/\n"
"│   ├── .env              # Application environment variables for development\n"
"│   ├── .gitignore        # Excludes override.env from version control\n"
"│   ├── compose.yml       # Development-specific Compose overrides\n"
"│   └── override.env.example  # Optional developer-local overrides template\n"
"├── test/\n"
"│   ├── .env              # Application environment variables for testing\n"
"│   ├── .gitignore        # Excludes override.env from version control\n"
"│   └── compose.yml       # Test-specific Compose overrides\n"
"└── prod/\n"
"    ├── .env              # Application environment variables for production\n"
"    ├── .gitignore        # Excludes override.env from version control\n"
"    └── compose.yml       # Production-specific Compose overrides (Docker Swarm)\n"
msgstr ""

#. type: Plain text
#: ../src/guide/tutorial/docker.md
msgid "Each subdirectory (`dev/`, `test/`, `prod/`) corresponds to an environment stage and contains its own `.env` file with application-level configuration and a `compose.yml` that extends the base `docker/compose.yml`."
msgstr ""

#. type: Title ##
#: ../src/guide/tutorial/docker.md
#, no-wrap
msgid "Environment files"
msgstr ""

#. type: Plain text
