msgstr ""

#. type: Plain text
#: ../src/guide/tutorial/docker.md
msgid "The two named volumes (`caddy_data` and `caddy_config`) persist Caddy's certificate storage and configuration across container restarts."
msgstr ""

#. type: Title ###
#: ../src/guide/tutorial/docker.md
#, no-wrap
msgid "docker/dev/compose.yml"
msgstr ""

#. type: Plain text
#: ../src/guide/tutorial/docker.md
msgid "Extends the base file for local development:"
msgstr ""

#. type: Fenced code block (yaml)
#: ../src/guide/tutorial/docker.md
#, no-wrap
msgid ""
"services:\n"
"  app:\n"
"    build:\n"
"      dockerfile: docker/Dockerfile\n"
"      context: ..\n"
"      target: dev\n"
"      args:\n"
"        USER_ID: ${UID}\n"
"        GROUP_ID: ${GID}\n"
"    env_file:\n"
"      - path: ./dev/.env\n"
"      - path: ./dev/override.env\n"
"        required: false\n"
"    ports:\n"
"      - \"${DEV_PORT:-80}:80\"\n"
"    volumes:\n"
"      - ../:/app\n"
"      - ../runtime:/app/runtime\n"
"      - caddy_data:/data\n"
"      - caddy_config:/config\n"
"    tty: true\n"
msgstr ""

