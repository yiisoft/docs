"curl -X POST http://localhost:8080/posts \\\n"
"    -H 'Content-Type: application/json' \\\n"
"    -H 'Accept: application/json' \\\n"
"    -d '{\"title\":\"First post\",\"content\":\"Text\"}'\n"
msgstr ""

