msgid "Quick start"
msgstr ""

#. type: Plain text
#: ../src/guide/rest/quick-start.md
msgid "Yii works with JSON APIs through the same PSR-7 request and response objects used by web pages.  For API endpoints, the usual flow is:"
msgstr ""

#. type: Bullet: '* '
#: ../src/guide/rest/quick-start.md
msgid "Parse the request body when the client sends JSON."
msgstr ""

#. type: Bullet: '* '
#: ../src/guide/rest/quick-start.md
msgid "Map request data to a typed input object."
msgstr ""

#. type: Bullet: '* '
#: ../src/guide/rest/quick-start.md
