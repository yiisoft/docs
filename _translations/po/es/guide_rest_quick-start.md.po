msgstr ""

#. type: Fenced code block (shell)
#: ../src/guide/rest/quick-start.md
#, no-wrap
msgid "make composer require yiisoft/input-http yiisoft/request-body-parser yiisoft/data-response\n"
msgstr ""

#. type: Plain text
#: ../src/guide/rest/quick-start.md
msgid "In `config/web/di/application.php`, add `RequestBodyParser` before `Router` so JSON requests are parsed before actions run:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/rest/quick-start.md
#, no-wrap
msgid ""
"use Yiisoft\\Request\\Body\\RequestBodyParser;\n"
"use Yiisoft\\Router\\Middleware\\Router;\n"
"\n"
"return [\n"
"    RequestBodyParser::class,\n"
"    Router::class,\n"
"];\n"
msgstr ""

#. type: Plain text
#: ../src/guide/rest/quick-start.md
msgid "In the same file, add JSON data response middleware before error handling and routing:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/rest/quick-start.md
#, no-wrap
msgid ""
"use Yiisoft\\DataResponse\\Formatter\\JsonFormatter;\n"
"use Yiisoft\\DataResponse\\Middleware\\ContentNegotiatorDataResponseMiddleware;\n"
"\n"
"return [\n"
"    static fn() => new ContentNegotiatorDataResponseMiddleware(\n"
"        formatters: [\n"
"            'application/json' => new JsonFormatter(),\n"
"        ],\n"
"        fallback: new JsonFormatter(),\n"
"    ),\n"
"    // error handling, request body parser, router, and not-found middleware\n"
"];\n"
msgstr ""

#. type: Plain text
#: ../src/guide/rest/quick-start.md
msgid "Also in `config/web/di/application.php`, configure action parameter resolvers:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/rest/quick-start.md
#, no-wrap
msgid ""
"use Yiisoft\\Definitions\\Reference;\n"
"use Yiisoft\\Input\\Http\\HydratorAttributeParametersResolver;\n"
"use Yiisoft\\Input\\Http\\RequestInputParametersResolver;\n"
"use Yiisoft\\Middleware\\Dispatcher\\CompositeParametersResolver;\n"
"use Yiisoft\\Middleware\\Dispatcher\\ParametersResolverInterface;\n"
"\n"
"return [\n"
"    ParametersResolverInterface::class => [\n"
"        'class' => CompositeParametersResolver::class,\n"
"        '__construct()' => [\n"
"            Reference::to(HydratorAttributeParametersResolver::class),\n"
"            Reference::to(RequestInputParametersResolver::class),\n"
"        ],\n"
"    ],\n"
"];\n"
msgstr ""

#. type: Plain text
#: ../src/guide/rest/quick-start.md
msgid "Use the [API application template configuration](https://github.com/yiisoft/app-api/blob/master/config/web/di/application.php)  as the complete reference for middleware order and resolver setup."
msgstr ""
