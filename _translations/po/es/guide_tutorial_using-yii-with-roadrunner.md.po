#, no-wrap
msgid "Using Yii with RoadRunner"
msgstr ""

#. type: Plain text
#: ../src/guide/tutorial/using-yii-with-roadrunner.md
#, no-wrap
msgid ""
"[RoadRunner](https://roadrunner.dev/) is a Golang-powered application server that integrates well with PHP. It runs\n"
"it as workers and each worker may handle multiple requests. Such an operation mode is often called\n"
"[event loop](using-with-event-loop.md) and allows not re-initializing a framework for each request that improves\n"
"performance significantly.\n"
msgstr ""

#. type: Plain text
#: ../src/guide/tutorial/using-yii-with-roadrunner.md
msgid "RoadRunner works on Linux, macOS and Windows. The best way to install it is to use a Composer:"
msgstr ""

#. type: Fenced code block
#: ../src/guide/tutorial/using-yii-with-roadrunner.md
#, no-wrap
msgid "composer require yiisoft/yii-runner-roadrunner\n"
msgstr ""

#. type: Plain text
#: ../src/guide/tutorial/using-yii-with-roadrunner.md
msgid "After installation is done, run"
msgstr ""

#. type: Fenced code block
#: ../src/guide/tutorial/using-yii-with-roadrunner.md
#, no-wrap
msgid "./vendor/bin/rr get\n"
msgstr ""

#. type: Plain text
#: ../src/guide/tutorial/using-yii-with-roadrunner.md
msgid "That would download ready to use RoadRunner server `rr` binary."
msgstr ""

#. type: Plain text
#: ../src/guide/tutorial/using-yii-with-roadrunner.md
msgid "First, we need to configure the server itself. Create `/.rr.yaml` and add the following config:"
msgstr ""

#. type: Fenced code block (yaml)
#: ../src/guide/tutorial/using-yii-with-roadrunner.md
#, no-wrap
msgid ""
"server:\n"
"  command: \"php worker.php\"\n"
"  env:\n"
"    YII_ENV: prod\n"
"    YII_DEBUG: false\n"
"\n"
"rpc:\n"
"  listen: tcp://127.0.0.1:6001\n"
"\n"
"http:\n"
"  address: :8080\n"
"  pool:\n"
"    debug: false # set to true for local development only\n"
"    supervisor:\n"
"      max_worker_memory: 192\n"
"  middleware: [static, gzip, headers, sendfile]\n"
"  static:\n"
"    dir:   \"public\"\n"
"    forbid: [\".php\", \".htaccess\"]\n"
"  headers:\n"
"    response:\n"
"      \"Cache-Control\": \"no-cache\"\n"
"\n"
"logs:\n"
"  mode: production\n"
"  level: warn\n"
msgstr ""

#. type: Plain text
#: ../src/guide/tutorial/using-yii-with-roadrunner.md
#, no-wrap
msgid ""
"> [!INFO]\n"
"> Read more about TLS, HTTP/2, HTTP/3 configuration and other middleware [on the RoadRunner docs](https://docs.roadrunner.dev/docs/http/http).\n"
msgstr ""

#. type: Plain text
#: ../src/guide/tutorial/using-yii-with-roadrunner.md
msgid "We're specifying that the entry script is `worker.php`, the server listens on port 8080, `public` directory files are served statically except `.php` and `.htaccess`. The `max_worker_memory` is a soft limit: if a worker exceeds 192 MB, it will restart after finishing its current request. Also, we're sending an additional header."
msgstr ""

#. type: Title ##
#: ../src/guide/tutorial/using-yii-with-roadrunner.md
#, no-wrap
msgid "KV cache"
msgstr ""

#. type: Plain text
#: ../src/guide/tutorial/using-yii-with-roadrunner.md
msgid "RoadRunner has a [KV plugin](https://docs.roadrunner.dev/docs/key-value/overview-kv) that can be used as a PSR-16 cache storage. It is useful when the application already runs under RoadRunner and needs a cache shared by workers."
msgstr ""

#. type: Plain text
#: ../src/guide/tutorial/using-yii-with-roadrunner.md
msgid "Install the PHP bridge and Yii cache package:"
msgstr ""

#. type: Fenced code block
#: ../src/guide/tutorial/using-yii-with-roadrunner.md
#, no-wrap
msgid "composer require spiral/roadrunner-kv yiisoft/cache\n"
msgstr ""

#. type: Plain text
#: ../src/guide/tutorial/using-yii-with-roadrunner.md
msgid "Add a KV storage to `.rr.yaml`:"
msgstr ""

#. type: Fenced code block (yaml)
#: ../src/guide/tutorial/using-yii-with-roadrunner.md
#, no-wrap
msgid ""
"kv:\n"
"  cache:\n"
"    driver: memory\n"
"    config:\n"
"      interval: 60\n"
msgstr ""

#. type: Plain text
#: ../src/guide/tutorial/using-yii-with-roadrunner.md
msgid "The `memory` driver stores values inside the RoadRunner process, so its data is lost when RoadRunner stops.  For persistent cache storage, use another KV driver from the RoadRunner documentation."
msgstr ""

#. type: Plain text
#: ../src/guide/tutorial/using-yii-with-roadrunner.md
msgid "Create `config/common/di/roadrunner-kv.php`:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/tutorial/using-yii-with-roadrunner.md
#, no-wrap
msgid ""
"<?php\n"
"\n"
"declare(strict_types=1);\n"
"\n"
"use Psr\\SimpleCache\\CacheInterface as SimpleCacheInterface;\n"
"use Spiral\\Goridge\\RPC\\RPC;\n"
"use Spiral\\RoadRunner\\KeyValue\\Factory;\n"
"use Spiral\\RoadRunner\\KeyValue\\StorageInterface;\n"
"use Yiisoft\\Cache\\Cache;\n"
"use Yiisoft\\Cache\\CacheInterface as YiiCacheInterface;\n"
"\n"
"return [\n"
"    StorageInterface::class => static function (): StorageInterface {\n"
"        $factory = new Factory(RPC::create('tcp://127.0.0.1:6001'));\n"
"\n"
"        return $factory->select('cache');\n"
"    },\n"
"\n"
"    SimpleCacheInterface::class => StorageInterface::class,\n"
"    YiiCacheInterface::class => Cache::class,\n"
"];\n"
msgstr ""

#. type: Plain text
#: ../src/guide/tutorial/using-yii-with-roadrunner.md
msgid "Now services can use `Yiisoft\\Cache\\CacheInterface` the same way as with other cache backends:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/tutorial/using-yii-with-roadrunner.md
#, fuzzy, no-wrap
#| msgid ""
#| "use Psr\\EventDispatcher\\EventDispatcherInterface;\n"
#| "\n"
#| "final readonly class SignupService\n"
#| "{\n"
#| "    public function __construct(\n"
#| "        private EventDispatcherInterface $eventDispatcher\n"
#| "    )\n"
#| "    {\n"
#| "    }\n"
#| "\n"
#| "    public function signup(SignupForm $form)\n"
#| "    {\n"
#| "        // handle signup\n"
#| "\n"
#| "        $event = new UserSignedUp($form);\n"
#| "        $this->eventDispatcher->dispatch($event);\n"
#| "    }\n"
#| "}\n"
msgid ""
"use Yiisoft\\Cache\\CacheInterface;\n"
"\n"
"final readonly class FeedService\n"
"{\n"
"    public function __construct(\n"
"        private CacheInterface $cache,\n"
"    ) {\n"
"    }\n"
"\n"
"    public function latest(): array\n"
"    {\n"
"        return $this->cache->getOrSet('feed-latest', fn (): array => $this->loadLatest(), 60);\n"
"    }\n"
"\n"
"    private function loadLatest(): array\n"
"    {\n"
"        return [];\n"
"    }\n"
"}\n"
msgstr ""
"use Psr\\EventDispatcher\\EventDispatcherInterface;\n"
"\n"
"final readonly class SignupService\n"
"{\n"
"    public function __construct(\n"
"        private EventDispatcherInterface $eventDispatcher\n"
"    )\n"
"    {\n"
"    }\n"
"\n"
"    public function signup(SignupForm $form)\n"
"    {\n"
"        // handle signup\n"
"\n"
"        $event = new UserSignedUp($form);\n"
"        $this->eventDispatcher->dispatch($event);\n"
"    }\n"
"}\n"

#. type: Plain text
#: ../src/guide/tutorial/using-yii-with-roadrunner.md
msgid "Create `/worker.php`:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/tutorial/using-yii-with-roadrunner.md
#, no-wrap
msgid ""
"<?php\n"
"\n"
"declare(strict_types=1);\n"
"\n"
"use Yiisoft\\Yii\\Runner\\RoadRunner\\RoadRunnerApplicationRunner;\n"
"\n"
"ini_set('display_errors', 'stderr');\n"
"\n"
"require_once __DIR__ . '/preload.php';\n"
"\n"
"(new RoadRunnerApplicationRunner(__DIR__, $_ENV['YII_DEBUG'], $_ENV['YII_ENV']))->run();\n"
msgstr ""

