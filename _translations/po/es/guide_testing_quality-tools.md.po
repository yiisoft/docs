#. type: Title ##
#: ../src/guide/testing/quality-tools.md
#, no-wrap
msgid "Composer Dependency Analyser"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/quality-tools.md
msgid "Composer Dependency Analyser checks that `composer.json` matches the classes used by the application."
msgstr ""

#. type: Plain text
#: ../src/guide/testing/quality-tools.md
msgid "Run it locally:"
msgstr ""

#. type: Fenced code block (shell)
#: ../src/guide/testing/quality-tools.md
#, no-wrap
msgid "vendor/bin/composer-dependency-analyser --config=composer-dependency-analyser.php\n"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/quality-tools.md
msgid "Run it in Docker:"
msgstr ""

#. type: Fenced code block (shell)
#: ../src/guide/testing/quality-tools.md
#, no-wrap
msgid "make composer-dependency-analyser\n"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/quality-tools.md
msgid "Use this check after adding or removing package usage in `src`, `config`, or `tests`."
msgstr ""

#. type: Title ##
#: ../src/guide/testing/quality-tools.md
#, no-wrap
msgid "PHP CS Fixer"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/quality-tools.md
msgid "PHP CS Fixer applies the project coding style from `.php-cs-fixer.php`."
msgstr ""

#. type: Fenced code block (shell)
#: ../src/guide/testing/quality-tools.md
#, no-wrap
msgid "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.php --diff\n"
msgstr ""

#. type: Fenced code block (shell)
#: ../src/guide/testing/quality-tools.md
#, no-wrap
msgid "make cs-fix\n"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/quality-tools.md
msgid "Commit formatting changes together with the code that needs them."
msgstr ""

#. type: Title ##
#: ../src/guide/testing/quality-tools.md
#, no-wrap
msgid "Rector"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/quality-tools.md
msgid "Rector applies configured code upgrades and refactorings from `rector.php`."
msgstr ""

#. type: Plain text
#: ../src/guide/testing/quality-tools.md
msgid "Preview changes locally:"
msgstr ""

#. type: Fenced code block (shell)
#: ../src/guide/testing/quality-tools.md
#, no-wrap
msgid "vendor/bin/rector --dry-run\n"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/quality-tools.md
msgid "Apply changes locally:"
msgstr ""

#. type: Fenced code block (shell)
#: ../src/guide/testing/quality-tools.md
#, no-wrap
msgid "vendor/bin/rector\n"
msgstr ""

#. type: Fenced code block (shell)
#: ../src/guide/testing/quality-tools.md
#, no-wrap
msgid "make rector\n"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/quality-tools.md
msgid "Review Rector changes before committing them. Automated refactoring can change behavior when custom rules or broad paths are configured."
msgstr ""

#. type: Title ##
#: ../src/guide/testing/quality-tools.md
#, no-wrap
msgid "Pull request checks"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/quality-tools.md
msgid "A practical local check before opening a pull request is:"
msgstr ""

#. type: Fenced code block (shell)
#: ../src/guide/testing/quality-tools.md
#, no-wrap
msgid ""
"APP_ENV=test vendor/bin/codecept build\n"
"APP_ENV=test vendor/bin/codecept run\n"
"vendor/bin/psalm\n"
"vendor/bin/composer-dependency-analyser --config=composer-dependency-analyser.php\n"
"vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.php --diff\n"
msgstr ""

#. type: Fenced code block (shell)
#: ../src/guide/testing/quality-tools.md
#, no-wrap
msgid ""
"make codecept build\n"
"make test\n"
"make psalm\n"
"make composer-dependency-analyser\n"
"make cs-fix\n"
msgstr ""
