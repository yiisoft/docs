#. type: Title ##
#: ../src/guide/concept/configuration.md ../src/guide/concept/events.md
#: ../src/internals/022-config-groups.md
#, no-wrap
msgid "Events"
msgstr "Event"

#. type: Plain text
#: ../src/guide/concept/events.md
msgid "Events allow you to run custom code at certain execution points without changing the code that emits the event.  You attach a custom code called a listener to an event. When the event is dispatched, the listener is executed."
msgstr ""

#. type: Plain text
#: ../src/guide/concept/events.md
msgid "For example, when a user signs up, you need to send a welcome email. You can do it in `SignupService`.  Later, when you also need to resize the user's avatar image, the service has to know about that too."
msgstr ""

#. type: Plain text
#: ../src/guide/concept/events.md
msgid "A cleaner flow is to dispatch a `UserSignedUp` event from `SignupService`. The welcome email sender and the avatar processor listen to this event. Additional signup-related work can be added by registering another listener."
msgstr ""

#. type: Plain text
#: ../src/guide/concept/events.md
msgid "Yii uses [yiisoft/yii-event](https://github.com/yiisoft/yii-event) for application event configuration. It builds on the [yiisoft/event-dispatcher](https://github.com/yiisoft/event-dispatcher) package, which provides a [PSR-14](https://www.php-fig.org/psr/psr-14/) compatible event dispatcher."
msgstr ""

#. type: Title ##
#: ../src/guide/concept/events.md
#, fuzzy, no-wrap
#| msgid "Resolving aliases <span id=\"resolving-aliases\"></span>"
msgid "Event classes <span id=\"event-classes\"></span>"
msgstr "Me-resolve alias <span id=\"resolving-aliases\"></span>"

#. type: Plain text
#: ../src/guide/concept/events.md
msgid "An event is an object. It usually contains data that listeners need:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/concept/events.md
#, no-wrap
msgid ""
"final readonly class UserSignedUp\n"
"{\n"
"    public function __construct(\n"
"        public SignupForm $form,\n"
"    ) {}\n"
"}\n"
msgstr ""

#. type: Title ##
#: ../src/guide/concept/events.md
#, fuzzy, no-wrap
#| msgid "Resolving aliases <span id=\"resolving-aliases\"></span>"
msgid "Event listeners <span id=\"event-listeners\"></span>"
msgstr "Me-resolve alias <span id=\"resolving-aliases\"></span>"

#. type: Plain text
#: ../src/guide/concept/events.md
msgid "An event listener is a [PHP callable](https://www.php.net/manual/en/language.types.callable.php) that receives an event:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/concept/events.md
#, no-wrap
msgid ""
"static function (UserSignedUp $event): void {\n"
"    // Send a welcome email.\n"
"}\n"
msgstr ""

#. type: Plain text
#: ../src/guide/concept/events.md
msgid "You can also use an invokable class:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/concept/events.md
#, no-wrap
msgid ""
"final readonly class WelcomeEmailSender\n"
"{\n"
"    public function __invoke(UserSignedUp $event): void\n"
"    {\n"
"        // Send a welcome email.\n"
"    }\n"
"}\n"
msgstr ""

#. type: Title ##
#: ../src/guide/concept/events.md
#, fuzzy, no-wrap
