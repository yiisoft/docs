#. type: Plain text
#: ../src/guide/concept/events.md
#, fuzzy
#| msgid "Configuration"
msgid "In an application, configure listeners in:"
msgstr "Konfigurasi"

#. type: Bullet: '- '
#: ../src/guide/concept/events.md
msgid "`config/events.php` for all application types."
msgstr ""

#. type: Bullet: '- '
#: ../src/guide/concept/events.md
msgid "`config/events-web.php` for web application events."
msgstr ""

#. type: Bullet: '- '
#: ../src/guide/concept/events.md
msgid "`config/events-console.php` for console application events."
msgstr ""

#. type: Plain text
#: ../src/guide/concept/events.md
msgid "The configuration is an array where keys are event class names and values are lists of listeners:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/concept/events.md
#, no-wrap
msgid ""
"<?php\n"
"\n"
"declare(strict_types=1);\n"
"\n"
"use App\\Event\\UserSignedUp;\n"
"use App\\EventListener\\WelcomeEmailSender;\n"
"use App\\Service\\AvatarProcessor;\n"
"\n"
"return [\n"
"    UserSignedUp::class => [\n"
"        WelcomeEmailSender::class,\n"
"        static fn (UserSignedUp $event, AvatarProcessor $avatarProcessor) => $avatarProcessor->resize($event->form),\n"
"    ],\n"
"];\n"
msgstr ""

#. type: Plain text
#: ../src/guide/concept/events.md
msgid "The listener may be a closure, a callable array, an invokable object, an invokable class name, or a DI alias.  For closure and callable array listeners, parameters after the first event parameter are resolved from the DI container.  Invokable class names are instantiated by the container."
msgstr ""

#. type: Plain text
#: ../src/guide/concept/events.md
msgid "Dependencies are resolved when the event is dispatched."
msgstr ""

#. type: Title ##
#: ../src/guide/concept/events.md
#, fuzzy, no-wrap
#| msgid "Using aliases in configuration <span id=\"using-aliases-in-configuration\"></span>"
msgid "Dispatching events <span id=\"dispatching-events\"></span>"
msgstr "Menggunakan aliases di konfigurasi <span id=\"using-aliases-in-configuration\"></span>"

#. type: Plain text
#: ../src/guide/concept/events.md
msgid "To dispatch an event, use `Psr\\EventDispatcher\\EventDispatcherInterface`:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/concept/events.md
#, no-wrap
msgid ""
"use Psr\\EventDispatcher\\EventDispatcherInterface;\n"
"\n"
"final readonly class SignupService\n"
"{\n"
"    public function __construct(\n"
"        private EventDispatcherInterface $eventDispatcher,\n"
"    ) {}\n"
"\n"
"    public function signup(SignupForm $form): void\n"
"    {\n"
"        // Sign up the user.\n"
"\n"
"        $this->eventDispatcher->dispatch(new UserSignedUp($form));\n"
"    }\n"
"}\n"
msgstr ""

#. type: Plain text
#: ../src/guide/concept/events.md
msgid "The dispatcher asks a listener provider for listeners that match the event and calls them one by one."
msgstr ""

#. type: Title ##
#: ../src/guide/concept/events.md
#, fuzzy, no-wrap
#| msgid "Resolving aliases <span id=\"resolving-aliases\"></span>"
msgid "Event listener order <span id=\"event-listener-order\"></span>"
msgstr "Me-resolve alias <span id=\"resolving-aliases\"></span>"

#. type: Plain text
#: ../src/guide/concept/events.md
msgid "When several listeners are configured for the same event, they are called in the order they are listed in the config.  If an event implements `Psr\\EventDispatcher\\StoppableEventInterface`, the dispatcher checks `isPropagationStopped()` before calling the next listener. When it returns `true`, the dispatcher stops processing the event."
msgstr ""

#. type: Plain text
#: ../src/guide/concept/events.md
msgid "Keep listeners independent where possible. Ordering is useful for technical needs, but business logic is usually easier to maintain when each listener can run on its own."
msgstr ""

#. type: Title ##
#: ../src/guide/concept/events.md
#, fuzzy, no-wrap
#| msgid "Resolving aliases <span id=\"resolving-aliases\"></span>"
msgid "Event hierarchy <span id=\"event-hierarchy\"></span>"
msgstr "Me-resolve alias <span id=\"resolving-aliases\"></span>"

#. type: Plain text
#: ../src/guide/concept/events.md
msgid "Events don't have names or wildcard matching. Event class names, interfaces, and inheritance can be used when one listener should handle several related events:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/concept/events.md
#, no-wrap
msgid ""
"interface DocumentEvent\n"
"{\n"
"}\n"
"\n"
"final readonly class BeforeDocumentProcessed implements DocumentEvent\n"
"{\n"
"}\n"
"\n"
"final readonly class AfterDocumentProcessed implements DocumentEvent\n"
"{\n"
"}\n"
msgstr ""

#. type: Plain text
#: ../src/guide/concept/events.md
msgid "With the interface, you can listen to all document-related events:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/concept/events.md
#, no-wrap
msgid ""
"use Yiisoft\\EventDispatcher\\Provider\\ListenerCollection;\n"
"use Yiisoft\\EventDispatcher\\Provider\\Provider;\n"
"\n"
"$listeners = (new ListenerCollection())\n"
"    ->add(static function (DocumentEvent $event): void {\n"
"        // Log document events.\n"
"    });\n"
"\n"
"$provider = new Provider($listeners);\n"
msgstr ""

#. type: Title ##
#: ../src/guide/concept/events.md
#, no-wrap
msgid "Manual listener provider setup <span id=\"manual-listener-provider-setup\"></span>"
msgstr ""

#. type: Plain text
#: ../src/guide/concept/events.md
msgid "In an application, use event configuration. For package-level code or tests, you can create a listener provider manually:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/concept/events.md
#, no-wrap
msgid ""
"use Yiisoft\\EventDispatcher\\Dispatcher\\Dispatcher;\n"
"use Yiisoft\\EventDispatcher\\Provider\\ListenerCollection;\n"
"use Yiisoft\\EventDispatcher\\Provider\\Provider;\n"
"\n"
"$listeners = (new ListenerCollection())\n"
"    ->add(static function (UserSignedUp $event): void {\n"
"        // Send a welcome email.\n"
"    });\n"
"\n"
"$provider = new Provider($listeners);\n"
"$dispatcher = new Dispatcher($provider);\n"
"\n"
"$dispatcher->dispatch(new UserSignedUp($form));\n"
msgstr ""

#. type: Plain text
#: ../src/guide/concept/events.md
#, no-wrap
msgid "`ListenerCollection::add()` returns a new collection instance. Assign the result when building a collection step by step:\n"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/concept/events.md
#, no-wrap
msgid ""
"$listeners = new ListenerCollection();\n"
"$listeners = $listeners->add(\n"
"    static function (UserSignedUp $event): void {\n"
"        // Send a welcome email.\n"
"    },\n"
"    UserSignedUp::class,\n"
");\n"
msgstr ""
