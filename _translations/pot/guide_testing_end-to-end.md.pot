#. type: Title #
#: ../src/guide/testing/end-to-end.md
#, no-wrap
msgid "End-to-end tests"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/end-to-end.md
msgid ""
"The Yii application template uses the `Web` Codeception suite for tests that "
"go through an HTTP server. These tests live in `tests/Web` and use "
"`App\\Tests\\Support\\WebTester`."
msgstr ""

#. type: Plain text
#: ../src/guide/testing/end-to-end.md
msgid ""
"Use web tests for user-visible HTTP behavior: pages, links, forms, "
"redirects, cookies, and error pages."
msgstr ""

#. type: Title ##
#: ../src/guide/testing/end-to-end.md
#, no-wrap
msgid "Web suite"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/end-to-end.md
msgid "The template configures `tests/Web.suite.yml` like this:"
msgstr ""

#. type: Fenced code block (yaml)
#: ../src/guide/testing/end-to-end.md ../src/guide/testing/environment-setup.md
#, no-wrap
msgid ""
"actor: WebTester\n"
"extensions:\n"
"  enabled:\n"
"    - Codeception\\Extension\\RunProcess:\n"
"        0: composer serve\n"
"        sleep: 3\n"
"modules:\n"
"  enabled:\n"
"    - PhpBrowser:\n"
"        url: http://127.0.0.1:8080\n"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/end-to-end.md
msgid ""
"`RunProcess` starts the application with the Composer `serve` script. "
"`PhpBrowser` sends HTTP requests to the server."
msgstr ""

#. type: Title ##
#: ../src/guide/testing/end-to-end.md ../src/guide/testing/functional.md
#, no-wrap
msgid "Test a page"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/end-to-end.md
msgid "The template includes `tests/Web/HomePageCest.php`:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/testing/end-to-end.md
#, no-wrap
msgid ""
"<?php\n"
"\n"
"declare(strict_types=1);\n"
"\n"
"namespace App\\Tests\\Web;\n"
"\n"
"use App\\Tests\\Support\\WebTester;\n"
"\n"
"final class HomePageCest\n"
"{\n"
"    public function base(WebTester $I): void\n"
"    {\n"
"        $I->wantTo('home page works.');\n"
"        $I->amOnPage('/');\n"
"        $I->expectTo('see page home.');\n"
"        $I->see('Hello!');\n"
"    }\n"
"}\n"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/end-to-end.md
msgid "Run the web suite locally:"
msgstr ""

#. type: Fenced code block (shell)
#: ../src/guide/testing/end-to-end.md
#, no-wrap
msgid "APP_ENV=test vendor/bin/codecept run Web\n"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/end-to-end.md ../src/guide/testing/unit.md
msgid "Run only this test:"
msgstr ""

#. type: Fenced code block (shell)
#: ../src/guide/testing/end-to-end.md
#, no-wrap
msgid "APP_ENV=test vendor/bin/codecept run Web HomePageCest\n"
msgstr ""

#. type: Fenced code block (shell)
#: ../src/guide/testing/end-to-end.md
#, no-wrap
msgid "make test Web\n"
msgstr ""

#. type: Title ##
#: ../src/guide/testing/end-to-end.md
#, no-wrap
msgid "Test links and error pages"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/end-to-end.md
msgid "Use the same actor methods for navigation and response assertions:"
msgstr ""

#. type: Fenced code block (php)
#: ../src/guide/testing/end-to-end.md
#, no-wrap
msgid ""
"<?php\n"
"\n"
"declare(strict_types=1);\n"
"\n"
"namespace App\\Tests\\Web;\n"
"\n"
"use App\\Tests\\Support\\WebTester;\n"
"\n"
"final class NotFoundHandlerCest\n"
"{\n"
"    public function nonExistentPage(WebTester $I): void\n"
"    {\n"
"        $I->wantTo('see 404 page.');\n"
"        $I->amOnPage('/non-existent-page');\n"
"        $I->canSeeResponseCodeIs(404);\n"
"        $I->see('404');\n"
"        $I->see('The page /non-existent-page not found.');\n"
"    }\n"
"}\n"
msgstr ""

#. type: Title ##
#: ../src/guide/testing/end-to-end.md
#, no-wrap
msgid "Smoke test with curl"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/end-to-end.md
msgid "For a deployment smoke test, start the application and check one URL:"
msgstr ""

#. type: Fenced code block (shell)
#: ../src/guide/testing/end-to-end.md
#, no-wrap
msgid "APP_ENV=test ./yii serve --port=8080\n"
msgstr ""

#. type: Plain text
#: ../src/guide/testing/end-to-end.md
msgid "In another terminal:"
msgstr ""

#. type: Fenced code block (shell)
#: ../src/guide/testing/end-to-end.md
#, no-wrap
msgid ""
"curl -fsS http://127.0.0.1:8080/ > /tmp/home.html\n"
"grep -q \"Hello!\" /tmp/home.html\n"
msgstr ""

