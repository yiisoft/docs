#. type: Title ##
#: ../src/guide/tutorial/i18n.md
#, no-wrap
msgid "Install packages"
msgstr ""

#. type: Plain text
#: ../src/guide/tutorial/i18n.md
msgid "Install the translator, locale helpers, and PHP-file message storage:"
