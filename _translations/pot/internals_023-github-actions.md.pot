#. type: Title #
#: ../src/internals/023-github-actions.md
#, no-wrap
msgid "023 — GitHub Actions"
msgstr ""

#. type: Plain text
#: ../src/internals/023-github-actions.md
msgid ""
"This document defines naming convention for the GitHub actions configuration "
"files."
msgstr ""

#. type: Title ##
#: ../src/internals/023-github-actions.md
#, no-wrap
msgid "Inputs and Outputs"
msgstr ""

#. type: Plain text
#: ../src/internals/023-github-actions.md
msgid "Input names and output names must use kebab-case format."
msgstr ""

#. type: Plain text
#: ../src/internals/023-github-actions.md
msgid "For example:"
msgstr ""

#. type: Fenced code block (yaml)
#: ../src/internals/023-github-actions.md
#, no-wrap
msgid ""
"inputs:\n"
"  my-input:\n"
"    description: 'My input'\n"
msgstr ""

#. type: Title ##
#: ../src/internals/023-github-actions.md
#, no-wrap
msgid "Secrets and Environment Variables"
msgstr ""

#. type: Plain text
#: ../src/internals/023-github-actions.md
msgid ""
"Secret names and environment variable names must use SCREAMING_SNAKE_CASE "
"format."
msgstr ""

#. type: Fenced code block (yaml)
#: ../src/internals/023-github-actions.md
#, no-wrap
msgid ""
"secrets:\n"
"  MY_SECRET:\n"
"    description: 'My secret'\n"
msgstr ""

#. type: Fenced code block (yaml)
#: ../src/internals/023-github-actions.md
#, no-wrap
msgid ""
"env:\n"
"  MY_ENV_VAR: 1\n"
msgstr ""
