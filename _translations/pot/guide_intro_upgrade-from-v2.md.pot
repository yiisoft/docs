msgid ""
"[Readonly properties](https://www.php.net/manual/en/"
"language.oop5.properties.php#language.oop5.properties.readonly-properties)"
msgstr ""

#. type: Bullet: '- '
#: ../src/guide/intro/upgrade-from-v2.md
msgid ""
"[Readonly classes](https://www.php.net/manual/en/"
"language.oop5.basic.php#language.oop5.basic.class.readonly)"
